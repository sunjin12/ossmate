{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python -X utf8 \"${CLAUDE_PLUGIN_ROOT}/.claude/hooks/pre_tool_use_guard.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python -X utf8 \"${CLAUDE_PLUGIN_ROOT}/.claude/hooks/post_tool_use_audit.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -X utf8 \"${CLAUDE_PLUGIN_ROOT}/.claude/hooks/user_prompt_router.py\"",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -X utf8 \"${CLAUDE_PLUGIN_ROOT}/.claude/hooks/session_start_brief.py\"",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -X utf8 \"${CLAUDE_PLUGIN_ROOT}/.claude/hooks/stop_summary.py\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
